# IDP_App Environment Configuration

# ==================== Ollama Configuration ====================
OLLAMA_HOST=localhost:11434
OLLAMA_MODEL=minimax-m2.5:cloud

# Alternative: Use cloud LLM
# OPENAI_API_KEY=sk-xxx
# LLM_PROVIDER=openai

# ==================== Embeddings ====================
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ==================== Vector Database ====================
CHROMA_PERSIST_DIR=./data/chroma_db

# ==================== Document Processing ====================
UPLOAD_DIR=./data/uploads
PROCESSED_DIR=./data/processed

# ==================== OCR Configuration ====================
TESSERACT_LANG=eng+deu

# ==================== App Configuration ====================
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860

# ==================== IDP Pipeline Configuration ====================

# Input/Output directories
INPUT_DIR=./input
OUTPUT_DIR=./output
FAILED_DIR=./data/failed

# Pipeline settings
BATCH_SIZE=10
MAX_RETRIES=3
RETRY_DELAY=1.0

# OCR settings
OCR_ENABLED=true
OCR_LANGUAGES=deu+eng

# Extraction settings
EXTRACTION_MODEL=minimax-m2.5:cloud
EXTRACTION_TIMEOUT=120
CONFIDENCE_THRESHOLD=0.7

# Validation settings (German invoice compliance)
VALIDATE_GERMAN_INVOICE=true
REQUIRE_TAX_ID=true
REQUIRE_INVOICE_NUMBER=true

# Export settings
EXPORT_FORMAT=json
# Options: json, csv, xml, hana, api, all
EXPORT_ON_SUCCESS=true
EXPORT_ON_VALIDATION_FAIL=false

# ==================== SAP HANA Configuration ====================
HANA_HOST=localhost
HANA_PORT=30015
HANA_USER=SYSTEM
HANA_PASSWORD=
HANA_TENANT=SYSTEMDB
HANA_SCHEMA=INVOICES
HANA_USE_SSL=false
HANA_SSL_VALIDATE=true

# ==================== REST API Configuration ====================
ERP_API_URL=http://localhost:8080
ERP_API_KEY=
ERP_API_USERNAME=
ERP_API_PASSWORD=
ERP_API_TIMEOUT=30
ERP_API_VERIFY_SSL=true

# ==================== Logging ====================
LOG_LEVEL=INFO
LOG_FILE=./idp_pipeline.log